# Copy these variables into Railway → Service → Variables
# (Do NOT commit real secrets to Git)

# Auth (required in production)
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me-strong-password
SESSION_TOKEN=generate-a-long-random-string

# Bakong KHQR (required for deposit QR + payment check)
BAKONG_API_TOKEN=
BAKONG_ACCOUNT_ID=yourname@bkrt
BAKONG_API_URL=https://api-bakong.nbc.gov.kh
BAKONG_MERCHANT_NAME=Payment
BAKONG_MERCHANT_CITY=Phnom Penh
BAKONG_QR_EXPIRE_MINUTES=15
BAKONG_DEFAULT_CURRENCY=USD

# Optional — merchant QR mode
# BAKONG_QR_MODE=merchant
# BAKONG_MERCHANT_ID=0
# BAKONG_ACQUIRING_BANK=ABAAKHPPXXX

# Railway sets PORT automatically — do not override unless you know why
# PORT=3000
